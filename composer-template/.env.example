# Rescue Platform Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# =============================================================================
# DATABASE
# =============================================================================
DB_HOST=db
DB_PORT=3306
DB_NAME=rescue_platform
DB_USER=rescue_platform
DB_PASSWORD=change_me_in_production
DB_ROOT_PASSWORD=change_me_in_production

# =============================================================================
# DRUPAL
# =============================================================================
DRUPAL_SITE_NAME="My Animal Rescue"
DRUPAL_SITE_MAIL=admin@myrescue.org
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASSWORD=change_me_in_production
DRUPAL_HASH_SALT=generate_a_random_74_char_string_here

# =============================================================================
# NEXT.JS FRONTEND
# =============================================================================
# URL of your Drupal backend (no trailing slash)
NEXT_PUBLIC_DRUPAL_BASE_URL=http://localhost:8080
DRUPAL_GRAPHQL_ENDPOINT=http://localhost:8080/graphql

# For production, set to your actual domain:
# NEXT_PUBLIC_DRUPAL_BASE_URL=https://cms.myrescue.org
# DRUPAL_GRAPHQL_ENDPOINT=https://cms.myrescue.org/graphql

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: development, staging, production
APP_ENV=development

# =============================================================================
# OPTIONAL: EMAIL (for contact forms and notifications)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@myrescue.org

# =============================================================================
# OPTIONAL: FILE STORAGE
# For production, use S3-compatible storage for uploaded files
# =============================================================================
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
